<script>
// ── DATA ──
const products = [
  { id:0, name:"ASUS ProArt Display 4K", cat:"Écrans", icon:"🖥️", price:749900, oldPrice:849900, specs:"32\" IPS 4K UHD · 60Hz · HDR600 · USB-C 96W · Calibré usine", desc:"Moniteur de création professionnelle avec une précision colorimétrique Delta E < 2 et une large couverture DCI-P3 95%. Idéal pour le design graphique, la retouche photo et la vidéo.", specItems:{Résolution:"3840×2160",Dalle:"IPS Nano",Taux:"60 Hz",Temps:"5 ms",HDR:"DisplayHDR 600"}, rating:"142 avis", badge:"new", stock:true },
  { id:1, name:"Samsung Odyssey G7 Curved", cat:"Écrans", icon:"🖥️", price:489900, specs:"27\" VA Curved 1440p · 240Hz · 1ms · G-Sync compatible · HDR600", desc:"Écran gaming courbé 1000R taillé pour la compétition. Le taux de rafraîchissement de 240 Hz et le temps de réponse de 1 ms assurent une fluidité absolue.", specItems:{Résolution:"2560×1440",Dalle:"VA Curved",Taux:"240 Hz",Temps:"1 ms",Courbure:"1000R"}, rating:"89 avis", stock:true },
  { id:2, name:"Keychron Q3 Pro", cat:"Périphériques", icon:"⌨️", price:184900, specs:"TKL · Hot-swap · Gateron G Pro Brown · Aluminium brossé · Bluetooth 5.1", desc:"Clavier mécanique premium 80% en aluminium anodisé avec hot-swap, compatible multi-appareils via Bluetooth ou câble USB-C. Frappe silencieuse et précise.", specItems:{Format:"TKL (80%)",Switch:"G Pro Brown",Boîtier:"Aluminium",Connexion:"USB-C / BT",RGB:"Oui"}, rating:"204 avis", badge:"new", stock:true },
  { id:3, name:"Logitech MX Master 3S", cat:"Périphériques", icon:"🖱️", price:84900, oldPrice:99900, specs:"8000 DPI · Molette MagSpeed · Ergonomique · Multi-appareil · USB-C", desc:"La souris de productivité ultime avec la molette MagSpeed ultra-rapide. Compatible Logi Bolt et Bluetooth, jusqu'à 3 appareils simultanément.", specItems:{DPI:"200–8000",Batterie:"70 jours",Connexion:"Bolt / BT",Boutons:"7",Poids:"141 g"}, rating:"512 avis", badge:"promo", stock:true },
  { id:4, name:"GeForce RTX 4070 Super", cat:"GPU", icon:"🎮", price:629900, oldPrice:699900, specs:"12 GB GDDR6X · DLSS 3 · Ray Tracing · 2560 MHz Boost · PCIe 4.0", desc:"La carte graphique parfaite pour le 1440p ultra et le 4K performant. DLSS 3 avec Frame Generation multiplie le nombre d'images par image IA.", specItems:{VRAM:"12 GB GDDR6X",Boost:"2560 MHz",TDP:"220W",Connecteurs:"3× DP · 1× HDMI",DLSS:"3.5"}, rating:"178 avis", badge:"promo", stock:true },
  { id:5, name:"AMD Ryzen 9 7950X", cat:"Processeurs", icon:"🔲", price:549900, specs:"16 cœurs · 32 threads · 5.7 GHz Boost · AM5 · PCIe 5.0 · 170W TDP", desc:"Processeur de workstation ultime pour le rendu 3D, la compilation et le multitâche intensif. Architecture Zen 4 avec 16 cœurs physiques.", specItems:{Cœurs:"16C / 32T",Boost:"5,7 GHz",Cache:"64 MB L3",Socket:"AM5",TDP:"170 W"}, rating:"93 avis", stock:true },
  { id:6, name:"Samsung 990 Pro 2 TB", cat:"Stockage", icon:"💾", price:149900, specs:"NVMe PCIe 4.0 · 7450 Mo/s lecture · 6900 Mo/s écriture · M.2 2280", desc:"SSD NVMe de nouvelle génération avec des vitesses séquentielles record. Idéal pour les postes créatifs et le gaming haute performance.", specItems:{Capacité:"2 000 GB",Lecture:"7 450 MB/s",Écriture:"6 900 MB/s",Interface:"PCIe 4.0 x4",Format:"M.2 2280"}, rating:"341 avis", badge:"new", stock:true },
  { id:7, name:"G.Skill Trident Z5 Neo", cat:"RAM", icon:"🧠", price:134900, specs:"32 GB (2×16) · DDR5-6000 · CL30 · RGB · AMD Expo · XMP 3.0", desc:"Kit mémoire DDR5 haute fréquence avec profil AMD Expo pour une compatibilité optimale sur les plateformes AM5 avec Ryzen 7000.", specItems:{Capacité:"32 GB",Type:"DDR5-6000",Latence:"CL30-38-38-96",Tension:"1,35V",RGB:"Oui"}, rating:"167 avis", stock:true },
];
 
let cart = [];
let currentProduct = null;
let currentQty = 1;
let currentCatFilter = 'Tout';
 
// ── NAVIGATION ──
function showPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  if (page === 'cart') renderCart();
  if (page === 'catalog') renderProducts();
}
 
function setActive(btn) {
  document.querySelectorAll('.nav-link').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}
 
// ── PRODUCTS ──
function filterCat(cat) {
  currentCatFilter = cat;
  const radios = { 'Tout':'c-all','Écrans':'c-ecran','Processeurs':'c-cpu','Périphériques':'c-peri','GPU':'c-gpu','Stockage':'c-storage','RAM':'c-ram' };
  if (radios[cat]) {
    const el = document.getElementById(radios[cat]);
    if (el) el.checked = true;
  }
  renderProducts();
}
 
function renderProducts() {
  const search = (document.getElementById('searchInput')?.value || '').toLowerCase();
  const sort = document.getElementById('sortSelect')?.value || 'default';
  const minP = parseFloat(document.getElementById('minPrice')?.value) || 0;
  const maxP = parseFloat(document.getElementById('maxPrice')?.value) || Infinity;
  const onlyStock = document.getElementById('inStock')?.checked;
  const onlySale = document.getElementById('onSale')?.checked;
 
  let filtered = products.filter(p => {
    if (currentCatFilter !== 'Tout' && p.cat !== currentCatFilter) return false;
    if (search && !p.name.toLowerCase().includes(search) && !p.cat.toLowerCase().includes(search)) return false;
    if (p.price < minP || p.price > maxP) return false;
    if (onlyStock && !p.stock) return false;
    if (onlySale && !p.oldPrice) return false;
    return true;
  });
 
  if (sort === 'price-asc') filtered.sort((a,b) => a.price - b.price);
  else if (sort === 'price-desc') filtered.sort((a,b) => b.price - a.price);
  else if (sort === 'name') filtered.sort((a,b) => a.name.localeCompare(b.name));
 
  document.getElementById('resultsCount').textContent = `${filtered.length} produit${filtered.length > 1 ? 's' : ''}`;
 
  const grid = document.getElementById('productsGrid');
  if (!filtered.length) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text-muted)"><div style="font-size:48px;margin-bottom:16px">🔍</div><div style="font-size:16px;font-weight:500">Aucun produit trouvé</div><div style="font-size:13px;margin-top:8px">Essayez d'autres filtres</div></div>`;
    return;
  }
 
  grid.innerHTML = filtered.map(p => {
    const badgeHtml = p.badge === 'new'
      ? `<span class="badge badge-new">NOUVEAU</span>`
      : p.badge === 'promo'
      ? `<span class="badge badge-promo">PROMO</span>`
      : '';
    const discount = p.oldPrice ? Math.round((1 - p.price/p.oldPrice)*100) : 0;
    return `
      <div class="product-card" onclick="showDetail(${p.id})">
        <div class="product-img">
          ${p.icon}
          <div class="product-badge-wrap">${badgeHtml}</div>
        </div>
        <div class="product-body">
          <div class="product-category">${p.cat}</div>
          <div class="product-name">${p.name}</div>
          <div class="product-specs">${p.specs}</div>
          <div class="product-footer">
            <div class="product-price">
              ${p.oldPrice ? `<span class="old-price">${p.oldPrice.toLocaleString('fr-DZ')} DA</span>` : ''}
              ${p.price.toLocaleString('fr-DZ')} DA
            </div>
            <button class="add-to-cart" onclick="event.stopPropagation(); addToCart(${p.id}, this)" title="Ajouter au panier">+</button>
          </div>
        </div>
      </div>`;
  }).join('');
}
 
// ── DETAIL ──
function showDetail(id) {
  currentProduct = products.find(p => p.id === id);
  currentQty = 1;
  if (!currentProduct) return;
  const p = currentProduct;
 
  document.getElementById('detailImg').textContent = p.icon;
  document.getElementById('detailCat').textContent = p.cat;
  document.getElementById('detailTitle').textContent = p.name;
  document.getElementById('detailRating').textContent = p.rating;
  document.getElementById('detailPrice').textContent = p.price.toLocaleString('fr-DZ') + ' DA';
  document.getElementById('breadcrumb-cat').textContent = p.cat;
  document.getElementById('breadcrumb-name').textContent = p.name;
 
  const oldP = document.getElementById('detailOldPrice');
  const disc = document.getElementById('detailDiscount');
  if (p.oldPrice) {
    oldP.textContent = p.oldPrice.toLocaleString('fr-DZ') + ' DA';
    disc.textContent = '-' + Math.round((1 - p.price/p.oldPrice)*100) + '%';
    disc.style.display = 'block';
  } else {
    oldP.textContent = '';
    disc.style.display = 'none';
  }
 
  document.getElementById('detailDesc').textContent = p.desc;
  document.getElementById('detailQty').textContent = 1;
 
  const specs = document.getElementById('detailSpecs');
  specs.innerHTML = Object.entries(p.specItems).map(([k,v]) => `
    <div class="spec-item"><div class="spec-label">${k}</div><div class="spec-value">${v}</div></div>
  `).join('');
 
  const btn = document.getElementById('detailAddBtn');
  btn.onclick = () => { for(let i=0; i<currentQty; i++) addToCart(p.id, null); };
 
  showPage('detail');
}
 
function changeQty(delta) {
  currentQty = Math.max(1, Math.min(99, currentQty + delta));
  document.getElementById('detailQty').textContent = currentQty;
}
 
// ── CART ──
function addToCart(id, btn) {
  const p = products.find(pr => pr.id === id);
  if (!p) return;
  const existing = cart.find(i => i.id === id);
  if (existing) existing.qty++;
  else cart.push({ ...p, qty: 1 });
  updateCartCount();
  showToast('✓ ' + p.name + ' ajouté au panier');
  if (btn) {
    btn.textContent = '✓';
    btn.classList.add('added');
    setTimeout(() => { btn.textContent = '+'; btn.classList.remove('added'); }, 1200);
  }
}
 
function updateCartCount() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('cartCount').textContent = total;
}
 
function renderCart() {
  const container = document.getElementById('cartItems');
  if (!cart.length) {
    container.innerHTML = `
      <div class="cart-empty">
        <span class="icon">🛒</span>
        <p>Votre panier est vide</p>
        <small>Explorez notre catalogue pour trouver votre bonheur</small>
        <br><br>
        <button class="btn-primary" style="margin:0 auto" onclick="showPage('catalog')">Voir le catalogue →</button>
      </div>`;
    document.getElementById('summarySubtotal').textContent = '0 DA';
    document.getElementById('summaryTotal').textContent = '0 DA';
    return;
  }
 
  container.innerHTML = cart.map((item, idx) => `
    <div class="cart-item">
      <div class="cart-item-img">${item.icon}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-spec">${item.cat}</div>
      </div>
      <div class="cart-item-qty">
        <button class="cqty-btn" onclick="updateQty(${idx}, -1)">−</button>
        <div class="cqty-num">${item.qty}</div>
        <button class="cqty-btn" onclick="updateQty(${idx}, 1)">+</button>
      </div>
      <div class="cart-item-price">${(item.price * item.qty).toLocaleString('fr-DZ')} DA</div>
      <button class="remove-btn" onclick="removeItem(${idx})" title="Supprimer">✕</button>
    </div>
  `).join('');
 
  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  document.getElementById('summarySubtotal').textContent = subtotal.toLocaleString('fr-DZ') + ' DA';
  document.getElementById('summaryTotal').textContent = subtotal.toLocaleString('fr-DZ') + ' DA';
}
 
function updateQty(idx, delta) {
  cart[idx].qty = Math.max(1, cart[idx].qty + delta);
  updateCartCount();
  renderCart();
}
 
function removeItem(idx) {
  cart.splice(idx, 1);
  updateCartCount();
  renderCart();
}
 
function checkout() {
  if (!cart.length) { showToast('⚠️ Votre panier est vide'); return; }
  cart = [];
  updateCartCount();
  renderCart();
  showToast('🎉 Commande passée avec succès !');
}
 
// ── TOAST ──
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}
 
// ── INIT ──
renderProducts();
</script>
